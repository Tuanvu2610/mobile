<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/filter"
    android:background="#FFFFFF">

    <!-- HEADER: Thanh màu vàng trên cùng -->
    <LinearLayout
        android:id="@+id/layoutHeader"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFC107"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_sort_by_size"
            app:tint="#FFFFFF" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="BỘ LỌC"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btnClose"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#FFFFFF" />
    </LinearLayout>

    <!-- BOTTOM BAR: Khu vực 2 nút Hủy / Áp Dụng cố định dưới đáy -->
    <LinearLayout
        android:id="@+id/layoutBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent">

        <!-- Đường kẻ ngang mờ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E0E0E0" />

        <!-- 2 Nút bấm -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp">

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:backgroundTint="#F5F5F5"
                android:text="HỦY"
                android:textColor="#333333"
                android:textSize="16sp"
                app:cornerRadius="4dp" />

            <Space
                android:layout_width="12dp"
                android:layout_height="wrap_content" />

            <Button
                android:onClick="chuyen"
                android:id="@+id/btnApply"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:backgroundTint="#FFC107"
                android:text="ÁP DỤNG"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                app:cornerRadius="4dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- CONTENT: Phần cuộn ở giữa -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/layoutBottom"
        app:layout_constraintTop_toBottomOf="@id/layoutHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Section 1: MENU -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MENU"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentEnd="true"
                    android:src="@android:drawable/arrow_down_float"
                    app:tint="#666666" />
            </RelativeLayout>

            <!-- Danh sách Menu -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="vertical">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="10dp" android:text="Trang chủ" android:textColor="#555555" android:textSize="15sp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="10dp" android:text="Sách Tiếng Anh -" android:textColor="#555555" android:textSize="15sp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="10dp" android:text="Sách Tiếng Pháp -" android:textColor="#555555" android:textSize="15sp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="10dp" android:text="Tác Giả Bán Chạy -" android:textColor="#555555" android:textSize="15sp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="10dp" android:text="Chuyên đề &amp; Tin tức -" android:textColor="#555555" android:textSize="15sp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="10dp" android:text="Về chúng tôi" android:textColor="#555555" android:textSize="15sp" />
            </LinearLayout>

            <!-- Đường phân cách -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="16dp"
                android:background="#EEEEEE" />

            <!-- Section 2: SẮP XẾP -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Sắp xếp"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentEnd="true"
                    android:src="@android:drawable/arrow_down_float"
                    app:tint="#666666" />
            </RelativeLayout>

            <!-- Danh sách Radio (Chỉ chọn 1) -->
            <!-- Chú ý: Dùng RadioGroup để đảm bảo người dùng chỉ được chọn 1 kiểu sắp xếp -->
            <RadioGroup
                android:id="@+id/rgSort"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <RadioButton android:id="@+id/rbPriceAsc" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp" android:text="Giá: Tăng dần" android:buttonTint="#FFC107" android:textColor="#555555" />
                <RadioButton android:id="@+id/rbPriceDesc" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp" android:text="Giá: Giảm dần" android:buttonTint="#FFC107" android:textColor="#555555" />
                <RadioButton android:id="@+id/rbNameAsc" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp" android:text="Tên: A-Z" android:buttonTint="#FFC107" android:textColor="#555555" />
                <RadioButton android:id="@+id/rbNameDesc" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp" android:text="Tên: Z-A" android:buttonTint="#FFC107" android:textColor="#555555" />
                <RadioButton android:id="@+id/rbOldest" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp" android:text="Cũ nhất" android:buttonTint="#FFC107" android:textColor="#555555" />
                <RadioButton android:id="@+id/rbNewest" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp" android:text="Mới nhất" android:checked="true" android:buttonTint="#FFC107" android:textColor="#555555" />
                <RadioButton android:id="@+id/rbBestSeller" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp" android:text="Bán chạy nhất" android:buttonTint="#FFC107" android:textColor="#555555" />
                <RadioButton android:id="@+id/rbStockDesc" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp" android:text="Tồn kho giảm dần" android:buttonTint="#FFC107" android:textColor="#555555" />

            </RadioGroup>
            <!-- Section 3: LỌC GIÁ -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Lọc giá"
                    android:textColor="#333333"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentEnd="true"
                    android:src="@android:drawable/arrow_down_float"
                    app:tint="#666666" />
            </RelativeLayout>

            <!-- Danh sách Radio (Chỉ chọn 1) -->
            <!-- Chú ý: Dùng RadioGroup để đảm bảo người dùng chỉ được chọn 1 kiểu sắp xếp -->
            <RadioGroup
                android:id="@+id/rgSortPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp">

                <RadioButton android:id="@+id/duoi1tr" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp" android:text="Dưới 1.000.000₫" android:buttonTint="#FFC107" android:textColor="#555555" />
                <RadioButton android:id="@+id/tu100toi300" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp" android:text="100.000₫ - 300.000₫" android:buttonTint="#FFC107" android:textColor="#555555" />
                <RadioButton android:id="@+id/tu300toi500" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp" android:text="300.000₫ - 500.000₫" android:buttonTint="#FFC107" android:textColor="#555555" />
                <RadioButton android:id="@+id/tu500toi1tr" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp" android:text="500.000đ - 1.000.000₫" android:buttonTint="#FFC107" android:textColor="#555555" />
                <RadioButton android:id="@+id/tren1tr" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="8dp" android:text="Trên 1.000.000₫" android:buttonTint="#FFC107" android:textColor="#555555" />

            </RadioGroup>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>