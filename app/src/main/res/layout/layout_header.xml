<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/layoutHeaderTop"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#004BA0"
    android:paddingStart="8dp"
    android:paddingTop="8dp"
    android:paddingEnd="8dp"
    android:paddingBottom="12dp"
    app:layout_constraintTop_toTopOf="parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <View
        android:id="@+id/topBarAnchor"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="4dp"
        app:layout_constraintBottom_toBottomOf="@id/topBarAnchor"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/topBarAnchor">

        <ImageView
            android:id="@+id/imgMenuIcon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_menu"
            app:tint="@android:color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="MENU"
            android:textColor="@android:color/white"
            android:textSize="10sp"
            android:textStyle="bold" />
    </LinearLayout>

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="120dp"
        android:layout_height="36dp"
        android:layout_marginStart="8dp"
        android:scaleType="fitCenter"
        app:layout_constraintBottom_toBottomOf="@id/topBarAnchor"
        app:layout_constraintStart_toEndOf="@id/layoutMenu"
        app:layout_constraintTop_toTopOf="@id/topBarAnchor" />

    <LinearLayout
        android:id="@+id/layoutLanguage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="4dp"
        app:layout_constraintBottom_toBottomOf="@id/topBarAnchor"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/topBarAnchor">

        <ImageView
            android:layout_width="32dp"
            android:layout_height="22dp"
            android:scaleType="centerCrop" />

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_marginStart="4dp"
            android:src="@drawable/ic_arrow_down"
            app:tint="@android:color/white" />
    </LinearLayout>

    <ImageView
        android:id="@+id/imgTruck"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:padding="6dp"
        android:src="@drawable/ic_truck"
        app:layout_constraintBottom_toBottomOf="@id/topBarAnchor"
        app:layout_constraintEnd_toStartOf="@id/layoutLanguage"
        app:layout_constraintTop_toTopOf="@id/topBarAnchor"
        app:tint="@android:color/white" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutCart"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        app:layout_constraintBottom_toBottomOf="@id/topBarAnchor"
        app:layout_constraintEnd_toStartOf="@id/imgTruck"
        app:layout_constraintTop_toTopOf="@id/topBarAnchor">

        <ImageView
            android:id="@+id/imgCart"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:padding="6dp"
            android:src="@drawable/ic_cart"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@android:color/white" />

        <TextView
            android:id="@+id/tvCartCount"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/bg_badge_red"
            android:gravity="center"
            android:text="0"
            android:textColor="@android:color/white"
            android:textSize="10sp"
            android:textStyle="bold"
            app:layout_constraintCircle="@id/imgCart"
            app:layout_constraintCircleAngle="45"
            app:layout_constraintCircleRadius="12dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageView
        android:id="@+id/imgUser"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="8dp"
        android:padding="6dp"
        android:src="@drawable/ic_user"
        app:layout_constraintBottom_toBottomOf="@id/topBarAnchor"
        app:layout_constraintEnd_toStartOf="@id/layoutCart"
        app:layout_constraintTop_toTopOf="@id/topBarAnchor"
        app:tint="@android:color/white" />

    <LinearLayout
        android:id="@+id/layoutSearchBar"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginHorizontal="4dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_search_bar"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        app:layout_constraintTop_toBottomOf="@id/topBarAnchor">

        <TextView
            android:id="@+id/txtSeach"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tìm kiếm sản phẩm..."
            android:textColor="#999999"
            android:textSize="14sp" />

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_search"
            app:tint="#666666" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>